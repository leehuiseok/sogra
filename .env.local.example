# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Inngest
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# AI (Step 4)
# AI_PROVIDER 로 text/image/video 라우팅 일괄 선택 — 기본값은 gemini
#   gemini  → gemini-2.5-flash (텍스트) + gemini-2.5-flash-image (이미지) + veo-3.0 (영상)
#   claude  → claude-haiku (텍스트)  ※ 이미지/영상은 openai/runway 로 fallback
#   openai  → gpt-4o-mini (텍스트) + dall-e-3 (이미지)
#   runway  → runway-gen3 (영상)
AI_PROVIDER=gemini
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
RUNWAY_API_KEY=

# Toss Payments (Step 6)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=

# External signals (Step 3)
OPENWEATHER_API_KEY=

# AI provider mock toggle (Step 4 RI-3) - true 시 외부 API 호출 없이 deterministic mock 반환
MOCK_AI_PROVIDERS=true

# Toss Payments mock toggle (Step 6) - true 시 외부 API 호출 없이 deterministic mock 반환
MOCK_TOSS=true
