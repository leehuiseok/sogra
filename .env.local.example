# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Inngest
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# AI (Step 4)
# AI_PROVIDER 는 text/image/video 의 default. 모달리티별 override 가능.
#   AI_TEXT_PROVIDER  > AI_PROVIDER  (gemini | claude | openai)
#   AI_IMAGE_PROVIDER > AI_PROVIDER  (gemini | openai)
#   AI_VIDEO_PROVIDER > AI_PROVIDER  (gemini | runway | pika)
# 권장 셋업: text/image = gemini, video = runway
AI_PROVIDER=gemini
AI_VIDEO_PROVIDER=runway
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
RUNWAY_API_KEY=

# Toss Payments (Step 6)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=

# External signals (Step 3)
OPENWEATHER_API_KEY=

# AI provider mock toggle (Step 4 RI-3) - true 시 외부 API 호출 없이 deterministic mock 반환
MOCK_AI_PROVIDERS=true

# Toss Payments mock toggle (Step 6) - true 시 외부 API 호출 없이 deterministic mock 반환
MOCK_TOSS=true
